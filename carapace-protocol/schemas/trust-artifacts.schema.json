{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://relayforge.tools/schemas/trust-artifacts.schema.json",
    "title": "Carapace Trust Artifacts",
    "description": "Shared JSON Schema definitions for agent identity cards, declared capabilities, verified capabilities, and standalone attestations.",
    "oneOf": [
        {
            "$ref": "#/$defs/AgentIdentityCard"
        },
        {
            "$ref": "#/$defs/DeclaredCapability"
        },
        {
            "$ref": "#/$defs/VerifiedCapability"
        },
        {
            "$ref": "#/$defs/Attestation"
        }
    ],
    "$defs": {
        "Signature": {
            "type": "object",
            "description": "Ed25519 signature over a JCS canonicalized payload.",
            "required": [
                "algorithm",
                "canonicalization",
                "public_key",
                "signature"
            ],
            "properties": {
                "algorithm": {
                    "const": "ed25519"
                },
                "canonicalization": {
                    "const": "rfc8785-jcs"
                },
                "public_key": {
                    "type": "string",
                    "description": "Base64url-encoded Ed25519 public key"
                },
                "signature": {
                    "type": "string",
                    "description": "Base64url signature over the canonicalized document"
                }
            },
            "additionalProperties": false
        },
        "EvidencePointer": {
            "type": "object",
            "required": [
                "uri",
                "digest_sha256"
            ],
            "properties": {
                "uri": {
                    "type": "string",
                    "format": "uri"
                },
                "digest_sha256": {
                    "type": "string",
                    "pattern": "^[A-Fa-f0-9]{64}$"
                },
                "notes": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "SchemaDescriptor": {
            "description": "Inline JSON Schema snippet or external reference.",
            "oneOf": [
                {
                    "type": [
                        "object",
                        "boolean"
                    ],
                    "additionalProperties": true
                },
                {
                    "type": "object",
                    "required": [
                        "$ref"
                    ],
                    "properties": {
                        "$ref": {
                            "type": "string",
                            "format": "uri"
                        }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "OwnerBlock": {
            "type": "object",
            "required": [
                "owner_claim",
                "owner_public_key",
                "verification_method"
            ],
            "properties": {
                "owner_claim": {
                    "type": "string",
                    "description": "Human-readable owner identifier"
                },
                "owner_public_key": {
                    "type": "string",
                    "description": "Base64url Ed25519 key used by the owner"
                },
                "verification_method": {
                    "type": "string",
                    "enum": [
                        "dns_txt",
                        "github_org",
                        "wallet_sig",
                        "manual_kyc",
                        "email_otp",
                        "did_auth",
                        "self_signed"
                    ]
                },
                "verification_evidence": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/EvidencePointer"
                    }
                },
                "verified_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "verifier": {
                    "type": "string",
                    "description": "Registry or attestor that confirmed ownership"
                }
            },
            "additionalProperties": false
        },
        "AttestationReference": {
            "type": "object",
            "required": [
                "uri",
                "digest_sha256"
            ],
            "properties": {
                "uri": {
                    "type": "string",
                    "format": "uri"
                },
                "digest_sha256": {
                    "type": "string",
                    "pattern": "^[A-Fa-f0-9]{64}$"
                },
                "label": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "AgentIdentityCard": {
            "type": "object",
            "required": [
                "schema_version",
                "agent_id",
                "name",
                "owner",
                "declared_capabilities",
                "endpoints",
                "status",
                "signature"
            ],
            "properties": {
                "schema_version": {
                    "type": "string"
                },
                "agent_id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "owner": {
                    "$ref": "#/$defs/OwnerBlock"
                },
                "declared_capabilities": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/DeclaredCapability"
                    }
                },
                "endpoints": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "protocol",
                            "url"
                        ],
                        "properties": {
                            "protocol": {
                                "type": "string",
                                "enum": [
                                    "https",
                                    "a2a",
                                    "mcp"
                                ]
                            },
                            "url": {
                                "type": "string",
                                "format": "uri"
                            },
                            "auth": {
                                "type": "string",
                                "enum": [
                                    "none",
                                    "api_key",
                                    "oauth",
                                    "custom"
                                ]
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "draft",
                        "active",
                        "degraded",
                        "suspended",
                        "revoked"
                    ]
                },
                "registry": {
                    "type": "object",
                    "properties": {
                        "registry_id": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        },
                        "uri": {
                            "type": "string",
                            "format": "uri"
                        }
                    },
                    "additionalProperties": false
                },
                "attestations": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/AttestationReference"
                    }
                },
                "signature": {
                    "$ref": "#/$defs/Signature"
                }
            },
            "additionalProperties": false
        },
        "DeclaredCapability": {
            "type": "object",
            "required": [
                "capability_id",
                "name",
                "description",
                "input_schema",
                "output_schema",
                "signature"
            ],
            "properties": {
                "capability_id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "input_schema": {
                    "$ref": "#/$defs/SchemaDescriptor"
                },
                "output_schema": {
                    "$ref": "#/$defs/SchemaDescriptor"
                },
                "release_version": {
                    "type": "string"
                },
                "evidence_pointer": {
                    "$ref": "#/$defs/EvidencePointer"
                },
                "last_updated": {
                    "type": "string",
                    "format": "date-time"
                },
                "signature": {
                    "$ref": "#/$defs/Signature"
                }
            },
            "additionalProperties": false
        },
        "VerifiedCapability": {
            "type": "object",
            "required": [
                "capability_id",
                "agent_id",
                "evaluator",
                "evaluation_method",
                "result",
                "signature"
            ],
            "properties": {
                "verification_id": {
                    "type": "string"
                },
                "capability_id": {
                    "type": "string"
                },
                "agent_id": {
                    "type": "string"
                },
                "evaluator": {
                    "type": "object",
                    "required": [
                        "evaluator_id",
                        "name",
                        "public_key"
                    ],
                    "properties": {
                        "evaluator_id": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        },
                        "public_key": {
                            "type": "string"
                        },
                        "contact": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "evaluation_method": {
                    "type": "string"
                },
                "environment": {
                    "type": "string",
                    "enum": [
                        "simulation",
                        "staging",
                        "production"
                    ]
                },
                "result": {
                    "type": "string",
                    "enum": [
                        "pass",
                        "fail",
                        "degraded",
                        "warning"
                    ]
                },
                "issued_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "expires_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "evidence": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/EvidencePointer"
                    }
                },
                "notes": {
                    "type": "string"
                },
                "signature": {
                    "$ref": "#/$defs/Signature"
                }
            },
            "additionalProperties": false
        },
        "Attestation": {
            "type": "object",
            "required": [
                "attestation_id",
                "attestor",
                "subject",
                "claims",
                "issued_at",
                "signature"
            ],
            "properties": {
                "schema_version": {
                    "type": "string"
                },
                "attestation_id": {
                    "type": "string"
                },
                "attestor": {
                    "type": "object",
                    "required": [
                        "attestor_id",
                        "name",
                        "public_key"
                    ],
                    "properties": {
                        "attestor_id": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        },
                        "public_key": {
                            "type": "string"
                        },
                        "contact": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "subject": {
                    "type": "object",
                    "required": [
                        "agent_id"
                    ],
                    "properties": {
                        "agent_id": {
                            "type": "string"
                        },
                        "capability_id": {
                            "type": "string"
                        },
                        "scope": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                },
                "claims": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "claim_type",
                            "value"
                        ],
                        "properties": {
                            "claim_type": {
                                "type": "string",
                                "description": "Namespaced claim identifier (e.g., capability.evaluation)"
                            },
                            "value": {
                                "type": [
                                    "string",
                                    "number",
                                    "boolean",
                                    "object",
                                    "array"
                                ]
                            },
                            "confidence": {
                                "type": "number",
                                "minimum": 0,
                                "maximum": 1
                            },
                            "evidence_pointer": {
                                "$ref": "#/$defs/EvidencePointer"
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "evidence": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/EvidencePointer"
                    }
                },
                "issued_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "expires_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "notes": {
                    "type": "string"
                },
                "signature": {
                    "$ref": "#/$defs/Signature"
                }
            },
            "additionalProperties": false
        }
    }
}
